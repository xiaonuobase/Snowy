    /**
     * 导入${subFunctionName}
     *
     * @author ${authorName}
     * @date ${genTime}
     **/
    JSONObject importData(MultipartFile file, String ${subForeignKeyCamelCase});

    /**
     * 导出${subFunctionName}
     *
     * @author ${authorName}
     * @date ${genTime}
     */
    void exportData(List<${subClassName}IdParam> ${subClassNameFirstLower}IdParamList, String ${subForeignKeyCamelCase}, HttpServletResponse response) throws IOException;
}
