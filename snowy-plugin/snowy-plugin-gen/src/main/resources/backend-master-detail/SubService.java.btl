package ${packageName}.${moduleName}.modular.${busName}.service;

import cn.hutool.json.JSONObject;
import com.baomidou.mybatisplus.extension.plugins.pagination.Page;
import com.baomidou.mybatisplus.extension.service.IService;
import jakarta.servlet.http.HttpServletResponse;
import org.springframework.web.multipart.MultipartFile;
import ${packageName}.${moduleName}.modular.${busName}.entity.${subClassName};
import ${packageName}.${moduleName}.modular.${busName}.param.${subClassName}AddParam;
import ${packageName}.${moduleName}.modular.${busName}.param.${subClassName}EditParam;
import ${packageName}.${moduleName}.modular.${busName}.param.${subClassName}IdParam;
import ${packageName}.${moduleName}.modular.${busName}.param.${subClassName}PageParam;
import java.io.Serializable;
import java.io.IOException;
import java.util.List;

/**
 * ${subFunctionName}Service接口
 *
 * @author ${authorName}
 * @date ${genTime}
 **/
public interface ${subClassName}Service extends IService<${subClassName}> {

    /**
     * 获取${subFunctionName}分页
     *
     * @author ${authorName}
     * @date ${genTime}
     */
    Page<${subClassName}> page(${subClassName}PageParam ${subClassNameFirstLower}PageParam);

    /**
     * 添加${subFunctionName}
     *
     * @author ${authorName}
     * @date ${genTime}
     */
    void add(${subClassName}AddParam ${subClassNameFirstLower}AddParam);

    /**
     * 编辑${subFunctionName}
     *
     * @author ${authorName}
     * @date ${genTime}
     */
    void edit(${subClassName}EditParam ${subClassNameFirstLower}EditParam);

    /**
     * 删除${subFunctionName}
     *
     * @author ${authorName}
     * @date ${genTime}
     */
    void delete(List<${subClassName}IdParam> ${subClassNameFirstLower}IdParamList);

    /**
     * 获取${subFunctionName}详情
     *
     * @author ${authorName}
     * @date ${genTime}
     */
    ${subClassName} detail(${subClassName}IdParam ${subClassNameFirstLower}IdParam);

    /**
     * 获取${subFunctionName}详情
     *
     * @author ${authorName}
     * @date ${genTime}
     **/
    ${subClassName} queryEntity(Serializable ${subDbTableKeyCamelCase});

    /**
     * 下载${subFunctionName}导入模板
     *
     * @author ${authorName}
     * @date ${genTime}
     */
